# Generated by Ansible - Do not edit manually

aws_region = "{{ route53_failover_state_region }}"

domain             = "{{ route53_failover_domain }}"
create_hosted_zone = {{ route53_failover_create_hosted_zone | lower }}
hosted_zone_id     = "{{ route53_failover_hosted_zone_id }}"

primary_ingress_hostname   = "{{ route53_failover_primary_ingress_hostname }}"
secondary_ingress_hostname = "{{ route53_failover_secondary_ingress_hostname }}"

primary_health_check_fqdn   = "{{ route53_failover_primary_health_fqdn }}"
secondary_health_check_fqdn = "{{ route53_failover_secondary_health_fqdn }}"

health_check_path = "{{ route53_failover_health_check_path }}"
attach_secondary_health_check = {{ 'true' if (route53_failover_attach_secondary_health_check | default(false) | bool) else 'false' }}
record_ttl        = {{ route53_failover_record_ttl }}

apps = [
{% for app in route53_failover_apps %}
  { name = "{{ app.name }}" },
{% endfor %}
]

tags = {
{% for key, value in route53_failover_tags.items() %}
  {{ key }} = "{{ value }}"
{% endfor %}
}
