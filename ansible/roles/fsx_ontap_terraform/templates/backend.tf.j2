# -----------------------------------------------------------------------------
# S3 Backend Configuration for FSx ONTAP Terraform State
# Generated by Ansible - Do not edit manually
# -----------------------------------------------------------------------------

terraform {
  backend "s3" {
    bucket         = "{{ fsx_ontap_terraform_state_bucket }}"
    key            = "{{ fsx_ontap_terraform_state_key }}"
    region         = "{{ fsx_ontap_terraform_state_region }}"
    encrypt        = true
    dynamodb_table = "{{ fsx_ontap_terraform_state_dynamodb_table }}"
  }
}
