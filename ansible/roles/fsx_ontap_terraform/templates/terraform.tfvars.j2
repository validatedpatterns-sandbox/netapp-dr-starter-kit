# -----------------------------------------------------------------------------
# Terraform Variables for FSx ONTAP
# Generated by Ansible - Do not edit manually
# -----------------------------------------------------------------------------

# AWS Configuration
aws_region = "{{ fsx_ontap_terraform_cluster_info.region }}"

# Network Configuration
vpc_id          = "{{ fsx_ontap_terraform_cluster_info.vpc_id }}"
subnet_ids      = {{ fsx_ontap_terraform_cluster_info.subnet_ids[:2] | to_json }}
route_table_ids = {{ fsx_ontap_terraform_cluster_info.route_table_ids | to_json }}
allowed_cidrs   = {{ fsx_ontap_terraform_allowed_cidrs | to_json }}

# FSx ONTAP Configuration
file_system_name                  = "{{ fsx_ontap_terraform_file_system_name }}"
storage_capacity                  = {{ fsx_ontap_terraform_storage_capacity }}
throughput_capacity               = {{ fsx_ontap_terraform_throughput_capacity }}
storage_type                      = "{{ fsx_ontap_terraform_storage_type }}"
deployment_type                   = "{{ fsx_ontap_terraform_deployment_type }}"
weekly_maintenance_time           = "{{ fsx_ontap_terraform_weekly_maintenance_time }}"
automatic_backup_retention_days   = {{ fsx_ontap_terraform_automatic_backup_retention_days }}
daily_automatic_backup_start_time = "{{ fsx_ontap_terraform_daily_automatic_backup_start_time }}"

# Passwords
fsx_admin_password = "{{ fsx_admin_password }}"
svm_admin_password = "{{ svm_admin_password }}"

# SVM Configuration
svm_name                   = "{{ fsx_ontap_terraform_svm_name }}"
root_volume_security_style = "{{ fsx_ontap_terraform_root_volume_security_style }}"

# Secrets Manager
create_secrets = {{ fsx_ontap_terraform_create_secrets | lower }}

# Tags
tags = {
{% for key, value in fsx_ontap_terraform_tags.items() %}
  {{ key }} = "{{ value }}"
{% endfor %}
}
