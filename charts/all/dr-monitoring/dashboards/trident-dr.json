        {
          "id": 1,
          "title": "AppVault",
          "type": "singlestat",
          "span": 3,
          "datasource": "$datasource",
          "targets": [
            {
              "expr": "min(kube_customresource_trident_appvault_state{vault_state=\"Available\"})",
              "format": "time_series",
              "instant": true,
              "refId": "A"
            }
          ],
          "valueName": "current",
          "valueMaps": [
            { "op": "=", "text": "OK", "value": "1" },
            { "op": "=", "text": "NOT OK", "value": "0" }
          ],
          "colorBackground": true,
          "colors": ["#d44a3a", "#d44a3a", "#299c46"],
          "thresholds": "1",
          "format": "none",
          "sparkline": { "show": false }
        },
        {
          "id": 2,
          "title": "AMRs Established",
          "type": "singlestat",
          "span": 3,
          "datasource": "$datasource",
          "targets": [
            {
              "expr": "count(kube_customresource_trident_amr_current_state{current_state_value=\"Established\"} == 1) or vector(0)",
              "format": "time_series",
              "instant": true,
              "refId": "A"
            }
          ],
          "valueName": "current",
          "colorBackground": true,
          "colors": ["#d44a3a", "#e5ac0e", "#299c46"],
